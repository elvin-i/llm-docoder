#!/usr/bin/env bash
set -euo pipefail

if [ -f /root/.llm/credentials.env ]; then
  set -a
  source /root/.llm/credentials.env
  set +a
fi

if [ -z "${ANTHROPIC_API_KEY:-}" ]; then
  echo "ANTHROPIC_API_KEY is not set. Run llm-setup first." >&2
  exit 1
fi

# 输出到 stdout：Claude Code 会把它当作 API Key
echo -n "$ANTHROPIC_API_KEY"
