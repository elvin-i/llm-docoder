#!/usr/bin/env bash
set -euo pipefail

if [ -f /root/.llm/credentials.env ]; then
  set -a
  source /root/.llm/credentials.env
  set +a
fi

LITE_PORT=4000
LITE_CONFIG=/litellm.yaml

echo "🚀 Starting LiteLLM (port ${LITE_PORT})..."
litellm --config "$LITE_CONFIG" --port "$LITE_PORT" &
LITE_PID=$!

cleanup() { kill "$LITE_PID" >/dev/null 2>&1 || true; }
trap cleanup EXIT

sleep 2

DEFAULT_MODEL=$(grep -E '^\s*-\s*model_name:\s*' "$LITE_CONFIG" \
  | head -n 1 \
  | sed -E 's/^\s*-\s*model_name:\s*//g' \
  | tr -d '\r')

if [ -z "$DEFAULT_MODEL" ]; then
  echo "❌ litellm.yaml 未检测到任何 model_name"
  exit 1
fi

echo "🌟 OpenCode started (default model: $DEFAULT_MODEL via env)"

OPENAI_API_BASE="http://localhost:$LITE_PORT" \
OPENAI_BASE_URL="http://localhost:$LITE_PORT" \
OPENAI_API_KEY="dummy-key" \
OPENCODE_MODEL="$DEFAULT_MODEL" \
OPENAI_MODEL="$DEFAULT_MODEL" \
exec opencode
