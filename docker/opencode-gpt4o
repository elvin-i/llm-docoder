#!/usr/bin/env bash
set -euo pipefail

if [ -f /root/.llm/credentials.env ]; then
  set -a
  source /root/.llm/credentials.env
  set +a
fi

LITE_PORT=4000
LITE_CONFIG=/litellm.yaml

echo "🚀 Starting LiteLLM (port ${LITE_PORT})..."
litellm --config "$LITE_CONFIG" --port "$LITE_PORT" &
LITE_PID=$!

cleanup() { kill "$LITE_PID" >/dev/null 2>&1 || true; }
trap cleanup EXIT

sleep 2

echo "🌟 OpenCode started (model: gpt-4o via env)"

OPENAI_API_BASE="http://localhost:$LITE_PORT" \
OPENAI_BASE_URL="http://localhost:$LITE_PORT" \
OPENAI_API_KEY="dummy-key" \
OPENCODE_MODEL="gpt-4o" \
OPENAI_MODEL="gpt-4o" \
exec opencode
