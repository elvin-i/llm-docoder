#!/usr/bin/env bash
set -euo pipefail

export PATH="/usr/local/bin:${PATH}"

ENV_FILE="/root/.config/llm-docoder/env.sh"
if [[ -f "$ENV_FILE" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "$ENV_FILE"
  set +a
fi

# Ensure Claude-specific env does NOT affect opencode
unset ANTHROPIC_API_KEY ANTHROPIC_AUTH_TOKEN CLAUDE_CODE_API_KEY_HELPER_TTL_MS

REAL=""
if [[ -x "/root/.opencode/bin/opencode" ]]; then
  REAL="/root/.opencode/bin/opencode"
elif [[ -x "/root/.local/bin/opencode" ]]; then
  REAL="/root/.local/bin/opencode"
else
  echo "[opencode wrapper] Cannot find real opencode binary."
  exit 1
fi

exec "${REAL}" "$@"
