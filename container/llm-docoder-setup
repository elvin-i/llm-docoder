#!/usr/bin/env bash
set -euo pipefail

ENV_DIR="/root/.config/llm-docoder"
ENV_FILE="${ENV_DIR}/env.sh"

OPENCODE_CFG_DIR="/root/.config/opencode"
OPENCODE_CFG_FILE="${OPENCODE_CFG_DIR}/opencode.json"

CLAUDE_DIR="/root/.claude"
CLAUDE_SETTINGS="${CLAUDE_DIR}/settings.json"
CLAUDE_KEY_HELPER="/usr/local/bin/claude-api-key-helper.sh"

mkdir -p "${ENV_DIR}" "${OPENCODE_CFG_DIR}" "${CLAUDE_DIR}"

# Read an existing value for a variable from (1) current env, then (2) ENV_FILE.
existing_var() {
  local var="$1"

  # Prefer current environment (entrypoint sources ENV_FILE already)
  local current="${!var-}"
  if [[ -n "${current}" ]]; then
    printf '%s' "${current}"
    return 0
  fi

  [[ -f "${ENV_FILE}" ]] || return 0

  # Use a subshell to avoid nounset pitfalls.
  bash -c "set +u; source \"${ENV_FILE}\" >/dev/null 2>&1; printf '%s' \"\${${var}-}\"" || true
}

mask_key() {
  local key="$1"
  local prefix_len=6
  local suffix_len=4
  local stars="*******"

  if (( ${#key} <= prefix_len + suffix_len )); then
    printf '%s' "${key}"
  else
    printf '%s%s%s' "${key:0:prefix_len}" "${stars}" "${key: -suffix_len}"
  fi
}

# Read secret input with '*' masking (Enter ends input)
read_secret() {
  local prompt="$1"
  local outvar="$2"
  local secret=""
  local ch

  echo -n "$prompt"

  stty -echo
  trap 'stty echo; echo; trap - INT TERM EXIT' INT TERM EXIT

  while true; do
    IFS= read -r -n1 ch

    # Enter => ch becomes empty string
    if [[ -z "$ch" ]]; then
      break
    fi

    # Backspace
    if [[ "$ch" == $'\177' ]]; then
      if [[ -n "$secret" ]]; then
        secret="${secret%?}"
        echo -ne "\b \b"
      fi
      continue
    fi

    secret+="$ch"
    echo -n "*"
  done

  stty echo
  trap - INT TERM EXIT
  echo ""

  printf -v "$outvar" "%s" "$secret"
}

prompt_api_key() {
  local label="$1"   # e.g. OpenAI API Key
  local var="$2"     # e.g. OPENAI_API_KEY
  local outvar="$3"  # where to store final value

  local existing=""
  existing="$(existing_var "${var}")"

  local input=""
  if [[ -n "${existing}" ]]; then
    local masked=""
    masked="$(mask_key "${existing}")"
    read_secret "${label} (${var}) [${masked}]: " input
    if [[ -z "${input}" ]]; then
      printf -v "${outvar}" '%s' "${existing}"
    else
      printf -v "${outvar}" '%s' "${input}"
    fi
  else
    read_secret "${label} (${var}) [Enter to skip]: " input
    printf -v "${outvar}" '%s' "${input}"
  fi
}

echo ""
echo "=== llm-docoder setup ==="
echo ""

OPENAI_API_KEY_INPUT=""
DASHSCOPE_API_KEY_INPUT=""
ANTHROPIC_API_KEY_INPUT=""

prompt_api_key "OpenAI API Key" "OPENAI_API_KEY" OPENAI_API_KEY_INPUT
prompt_api_key "DashScope API Key" "DASHSCOPE_API_KEY" DASHSCOPE_API_KEY_INPUT
prompt_api_key "Anthropic API Key" "ANTHROPIC_API_KEY" ANTHROPIC_API_KEY_INPUT

echo ""
echo "DashScope (OpenAI-compatible) baseURL options:"
echo "  1) Beijing    https://dashscope.aliyuncs.com/compatible-mode/v1"
echo "  2) Singapore  https://dashscope-intl.aliyuncs.com/compatible-mode/v1"
echo "  3) Virginia   https://dashscope-us.aliyuncs.com/compatible-mode/v1"
echo "  4) Custom"
read -r -p "Choose [1-4] (default 1): " DS_URL_CHOICE || true
DS_URL_CHOICE="${DS_URL_CHOICE:-1}"

DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
case "${DS_URL_CHOICE}" in
  1) DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1" ;;
  2) DASHSCOPE_BASE_URL="https://dashscope-intl.aliyuncs.com/compatible-mode/v1" ;;
  3) DASHSCOPE_BASE_URL="https://dashscope-us.aliyuncs.com/compatible-mode/v1" ;;
  4) read -r -p "Enter custom baseURL (must end with /v1): " DASHSCOPE_BASE_URL ;;
  *) echo "Invalid choice, using default Beijing." ;;
esac

# Persist env.sh (ONLY inside container)
{
  echo "# Generated by llm-docoder-setup on $(date -Is)"
  echo ""
  [[ -n "${OPENAI_API_KEY_INPUT}" ]] && echo "export OPENAI_API_KEY='${OPENAI_API_KEY_INPUT}'"
  [[ -n "${DASHSCOPE_API_KEY_INPUT}" ]] && echo "export DASHSCOPE_API_KEY='${DASHSCOPE_API_KEY_INPUT}'"
  [[ -n "${ANTHROPIC_API_KEY_INPUT}" ]] && echo "export ANTHROPIC_API_KEY='${ANTHROPIC_API_KEY_INPUT}'"
  echo "export CLAUDE_CODE_API_KEY_HELPER_TTL_MS='3600000'"
} > "${ENV_FILE}"
chmod 600 "${ENV_FILE}"

# Claude settings: use apiKeyHelper (executed with /bin/sh) to retrieve API key
cat > "${CLAUDE_SETTINGS}" <<'EOF'
{
  "forceLoginMethod": "console",
  "apiKeyHelper": "/usr/local/bin/claude-api-key-helper.sh",
  "env": {
    "CLAUDE_CODE_API_KEY_HELPER_TTL_MS": "3600000"
  }
}
EOF
chmod 600 "${CLAUDE_SETTINGS}"

# Default model selection for OpenCode
DEFAULT_MODEL=""
if [[ -n "${OPENAI_API_KEY_INPUT}" ]]; then
  DEFAULT_MODEL="openai/gpt-5.2"
elif [[ -n "${DASHSCOPE_API_KEY_INPUT}" ]]; then
  DEFAULT_MODEL="dashscope/qwen3-coder-plus"
else
  DEFAULT_MODEL="dashscope/qwen3-coder-plus"
fi

# Generate OpenCode config (no Anthropic vars referenced here)
cat > "${OPENCODE_CFG_FILE}" <<EOF
{
  "\$schema": "https://opencode.ai/config.json",
  "model": "${DEFAULT_MODEL}",
  "provider": {
    "openai": {
      "npm": "@ai-sdk/openai",
      "name": "OpenAI (official)",
      "options": {
        "apiKey": "{env:OPENAI_API_KEY}"
      },
      "models": {
        "gpt-4o":  { "name": "GPT-4o" },
        "gpt-4.1": { "name": "GPT-4.1" },
        "gpt-5.1": { "name": "GPT-5.1" },
        "gpt-5.2": { "name": "GPT-5.2" }
      }
    },
    "dashscope": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DashScope (Qwen + DeepSeek, OpenAI-compatible)",
      "options": {
        "baseURL": "${DASHSCOPE_BASE_URL}",
        "apiKey": "{env:DASHSCOPE_API_KEY}"
      },
      "models": {
        "qwen3-coder-plus":  { "name": "Qwen3 Coder Plus" },
        "deepseek-v3.2":     { "name": "DeepSeek v3.2" },
        "deepseek-v3.1":     { "name": "DeepSeek v3.1" },
        "deepseek-v3":       { "name": "DeepSeek v3" },
        "deepseek-r1":       { "name": "DeepSeek R1" }
      }
    }
  }
}
EOF
chmod 600 "${OPENCODE_CFG_FILE}"

echo ""
echo "✅ Setup complete."
echo " - Env saved to: ${ENV_FILE}"
echo " - Claude settings: ${CLAUDE_SETTINGS}"
echo " - OpenCode config: ${OPENCODE_CFG_FILE}"
echo ""
echo "Now run:"
echo "  claude"
echo "  opencode"
echo ""
