#!/usr/bin/env bash
set -euo pipefail

ENV_DIR="/root/.config/llm-docoder"
ENV_FILE="${ENV_DIR}/env.sh"
OPENCODE_CFG_DIR="/root/.config/opencode"
OPENCODE_CFG_FILE="${OPENCODE_CFG_DIR}/opencode.json"

mkdir -p "${ENV_DIR}" "${OPENCODE_CFG_DIR}"

# Read secret input with '*' masking (Enter ends input)
read_secret() {
  local prompt="$1"
  local outvar="$2"
  local secret=""
  local ch

  echo -n "$prompt"

  stty -echo
  trap 'stty echo; echo; trap - INT TERM EXIT' INT TERM EXIT

  while true; do
    IFS= read -r -n1 ch

    # Enter => ch becomes empty string
    if [[ -z "$ch" ]]; then
      break
    fi

    # Backspace
    if [[ "$ch" == $'\177' ]]; then
      if [[ -n "$secret" ]]; then
        secret="${secret%?}"
        echo -ne "\b \b"
      fi
      continue
    fi

    secret+="$ch"
    echo -n "*"
  done

  stty echo
  trap - INT TERM EXIT
  echo ""

  printf -v "$outvar" "%s" "$secret"
}

echo ""
echo "=== llm-docoder setup ==="
echo ""

OPENAI_API_KEY_INPUT=""
DASHSCOPE_API_KEY_INPUT=""

read_secret "OpenAI API Key (OPENAI_API_KEY) [Enter to skip]: " OPENAI_API_KEY_INPUT
read_secret "DashScope API Key (DASHSCOPE_API_KEY) [Enter to skip]: " DASHSCOPE_API_KEY_INPUT

echo ""
echo "DashScope (OpenAI-compatible) baseURL options:"
echo "  1) Beijing    https://dashscope.aliyuncs.com/compatible-mode/v1"
echo "  2) Singapore  https://dashscope-intl.aliyuncs.com/compatible-mode/v1"
echo "  3) Virginia   https://dashscope-us.aliyuncs.com/compatible-mode/v1"
echo "  4) Custom"
read -r -p "Choose [1-4] (default 1): " DS_URL_CHOICE || true
DS_URL_CHOICE="${DS_URL_CHOICE:-1}"

DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
case "${DS_URL_CHOICE}" in
  1) DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1" ;;
  2) DASHSCOPE_BASE_URL="https://dashscope-intl.aliyuncs.com/compatible-mode/v1" ;;
  3) DASHSCOPE_BASE_URL="https://dashscope-us.aliyuncs.com/compatible-mode/v1" ;;
  4) read -r -p "Enter custom baseURL (must end with /v1): " DASHSCOPE_BASE_URL ;;
  *) echo "Invalid choice, using default Beijing." ;;
esac

# Persist env.sh (ONLY inside container)
{
  echo "# Generated by llm-docoder-setup on $(date -Is)"
  echo ""
  if [[ -n "${OPENAI_API_KEY_INPUT}" ]]; then
    echo "export OPENAI_API_KEY='${OPENAI_API_KEY_INPUT}'"
  fi
  if [[ -n "${DASHSCOPE_API_KEY_INPUT}" ]]; then
    echo "export DASHSCOPE_API_KEY='${DASHSCOPE_API_KEY_INPUT}'"
  fi
} > "${ENV_FILE}"
chmod 600 "${ENV_FILE}"

# Default model selection
DEFAULT_MODEL=""
if [[ -n "${OPENAI_API_KEY_INPUT}" ]]; then
  DEFAULT_MODEL="openai/gpt-5.2"
elif [[ -n "${DASHSCOPE_API_KEY_INPUT}" ]]; then
  DEFAULT_MODEL="dashscope/qwen3-coder-plus"
else
  DEFAULT_MODEL="dashscope/qwen3-coder-plus"
fi

# Generate OpenCode config
cat > "${OPENCODE_CFG_FILE}" <<EOF
{
  "\$schema": "https://opencode.ai/config.json",
  "model": "${DEFAULT_MODEL}",
  "provider": {
    "openai": {
      "npm": "@ai-sdk/openai",
      "name": "OpenAI (official)",
      "options": {
        "apiKey": "{env:OPENAI_API_KEY}"
      },
      "models": {
        "gpt-4o":  { "name": "GPT-4o" },
        "gpt-4.1": { "name": "GPT-4.1" },
        "gpt-5.1": { "name": "GPT-5.1" },
        "gpt-5.2": { "name": "GPT-5.2" }
      }
    },
    "dashscope": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DashScope (Qwen + DeepSeek, OpenAI-compatible)",
      "options": {
        "baseURL": "${DASHSCOPE_BASE_URL}",
        "apiKey": "{env:DASHSCOPE_API_KEY}"
      },
      "models": {
        "qwen3-coder-plus":  { "name": "Qwen3 Coder Plus" },
        "deepseek-v3.2":     { "name": "DeepSeek v3.2" },
        "deepseek-v3.1":     { "name": "DeepSeek v3.1" },
        "deepseek-v3":       { "name": "DeepSeek v3" },
        "deepseek-r1":       { "name": "DeepSeek R1" }
      }
    }
  }
}
EOF
chmod 600 "${OPENCODE_CFG_FILE}"

echo ""
echo "✅ Setup complete."
echo " - Env saved to: ${ENV_FILE}"
echo " - OpenCode config: ${OPENCODE_CFG_FILE}"
echo ""
echo "Now run:"
echo "  rm -rf ~/.cache/opencode"
echo "  opencode"
echo ""
